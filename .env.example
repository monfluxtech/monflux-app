# Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=your-secret-key-change-in-production
# Optional — encrypts e-signature data at rest (pgcrypto). Falls back to JWT_SECRET if unset,
# and falls back further to plaintext storage if the pgcrypto extension isn't available on the DB host.
SIGNATURE_ENCRYPTION_KEY=your-signature-encryption-key
ANTHROPIC_API_KEY=your-anthropic-api-key
# Required for supplier-invoice drag-and-drop upload (Vercel Blob free tier).
# Get it from: Vercel dashboard → your project → Storage → Create Database → Blob → copy the read/write token.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Frontend
VITE_API_BASE=http://localhost:5000/api

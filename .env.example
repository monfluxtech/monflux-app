# Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=your-secret-key-change-in-production
# Optional — encrypts e-signature data at rest (pgcrypto). Falls back to JWT_SECRET if unset,
# and falls back further to plaintext storage if the pgcrypto extension isn't available on the DB host.
SIGNATURE_ENCRYPTION_KEY=your-signature-encryption-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Frontend
VITE_API_BASE=http://localhost:5000/api

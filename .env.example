# Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=your-secret-key-change-in-production
# Optional — encrypts e-signature data at rest (pgcrypto). Falls back to JWT_SECRET if unset,
# and falls back further to plaintext storage if the pgcrypto extension isn't available on the DB host.
SIGNATURE_ENCRYPTION_KEY=your-signature-encryption-key
ANTHROPIC_API_KEY=your-anthropic-api-key
# Required for supplier-invoice drag-and-drop upload (Vercel Blob free tier).
# Get it from: Vercel dashboard → your project → Storage → Create Database → Blob → copy the read/write token.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
# Required for the "Générer prévisualisation" vision-preview feature (image-to-image editing
# of a pre-chantier photo, ~$0.04/image). Get a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Model id — Google is mid-transition from gemini-2.5-flash-image (sunsets Oct 2026) to
# gemini-3.1-flash-image-preview. Override here without a deploy if the default 404s.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Frontend
VITE_API_BASE=http://localhost:5000/api
